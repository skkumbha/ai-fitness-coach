# Production — copy to .env.prod on the server (never commit .env.prod):
#   cp .env.prod.example .env.prod

# Docker image (change tag to test a branch before merging to main)
# Stable release:   sreeramkumbham/fitness-assistant-frontend:latest
# Branch experiment: sreeramkumbham/fitness-assistant-frontend:feat-telegarm-v1
FRONTEND_IMAGE_REPO=sreeramkumbham/fitness-assistant-frontend
FRONTEND_IMAGE_NAME=sreeramkumbham/fitness-assistant-frontend:latest
FRONTEND_CONTAINER_NAME=fa-f
FRONTEND_PORT=8080
